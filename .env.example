# Docker 部署环境变量配置
# 复制此文件为 .env 并修改值

# ============================================================
# 基础配置
# ============================================================
# MySQL 数据库名
DB_NAME=claimcraft
# MySQL 用户名
DB_USER=root
# MySQL root 密码
DB_PASSWORD=claimcraft_dev_2025
# MySQL 主机（本地 Windows 直连使用 127.0.0.1；Docker 部署时改为 mysql）
DB_HOST=127.0.0.1
# MySQL 端口
DB_PORT=3306

# Django 生产密钥（请更改为随机字符串）
SECRET_KEY=claimcraft-prod-secret-change-me


# ============================================================
# LLM 大模型配置总览
# ------------------------------------------------------------
# 本项目所有 LLM 调用按使用场景分组，每组独立配置供应商/凭证/参数。
# 场景清单：
#   1. 文本生成（投诉/字段抽取降级/证据分类/证据链/时间线分类）→ LLM_*
#   2. OCR 视觉识别（多模态图像 OCR，如 DeepSeek-OCR）          → LLM_OCR_*
#   3. PaddleOCR-VL 云端（aistudio 高精度文档识别）              → PADDLEOCR_VL_*
#   4. LangExtract（基于 Qwen3 的信息抽取，字段抽取首选）        → LANGEXTRACT_*
#   5. LLM 通用调用参数（重试/超时等跨场景共享）                 → LLM_COMMON_*
#   6. LangGraph Checkpointer 持久化（PostgreSQL，独立于 MySQL） → CHECKPOINTER_*
#   7. LangSmith 观察配置（全链路 trace 追踪）                  → LANGSMITH_*
# 所有配置均通过 OpenAI 兼容协议或各自原生 SDK 接入，运行时切换。
# ============================================================


# ------------------------------------------------------------
# 1. 文本 LLM（投诉生成/证据分类/证据链构造/字段抽取降级）
# ------------------------------------------------------------
# 供应商：deepseek | siliconflow | qwen | glm | openai | custom
# 硅基流动 SiliconFlow 托管 DeepSeek 全系列文本模型
LLM_PROVIDER=siliconflow

# API Key（必填，未配置则文本 LLM 降级为正则/模板）
LLM_API_KEY=

# Base URL（留空则按 LLM_PROVIDER 自动选择预设）
# DeepSeek:    https://api.deepseek.com/v1
# SiliconFlow: https://api.siliconflow.cn/v1
# Qwen:        https://dashscope.aliyuncs.com/compatible-mode/v1
# GLM:         https://open.bigmodel.cn/api/paas/v4
# OpenAI:      https://api.openai.com/v1
LLM_BASE_URL=

# 文本模型名（留空则按 LLM_PROVIDER 自动选择预设）
# SiliconFlow: deepseek-ai/DeepSeek-V3
# DeepSeek:    deepseek-chat
# Qwen:        qwen-max
# GLM:         glm-4
# OpenAI:      gpt-4o-mini
LLM_MODEL=

# 调用参数（温度/超时/重试次数）
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3


# ------------------------------------------------------------
# 2. OCR 视觉 LLM（多模态图像 OCR，与文本 LLM 解耦）
# ------------------------------------------------------------
# 适用场景：多模态 LLM 视觉识别（如 DeepSeek-OCR / GPT-4o / Qwen-VL）
# 适用策略：OCR_STRATEGIES 中包含 "llm_vision" 时生效
# 与文本 LLM 共享 OpenAI 兼容协议，但供应商/模型/凭证/参数完全独立
#
# 已确定使用：硅基流动 SiliconFlow 托管的 DeepSeek-OCR
LLM_OCR_PROVIDER=siliconflow

# OCR 视觉模型专用 API Key（与 LLM_API_KEY 解耦，便于按供应商/账户隔离）
# 不填则自动回退到 LLM_API_KEY（向后兼容）
LLM_OCR_API_KEY=

# OCR 视觉模型 Base URL（留空则按 LLM_OCR_PROVIDER 自动选择预设）
LLM_OCR_BASE_URL=

# OCR 视觉模型名
# 硅基流动 DeepSeek-OCR：deepseek-ai/DeepSeek-OCR
# 通义千问视觉：       qwen-vl-max
# OpenAI GPT-4o：      gpt-4o
LLM_OCR_MODEL=deepseek-ai/DeepSeek-OCR

# OCR 视觉模型调用参数（识别任务 temperature 偏低，timeout 略长以容纳图片上传）
LLM_OCR_TEMPERATURE=0.1
LLM_OCR_TIMEOUT=60
LLM_OCR_MAX_RETRIES=3

# LLM 视觉 OCR 的提示词（留空使用内置默认）
# 默认：请识别并提取这张图片中的所有文字内容，保持原始结构（换行/标点），仅输出识别到的文字，不要其他解释。
LLM_OCR_PROMPT=

# 上传图片大小上限（MB），超过则压缩（留空使用默认 10）
LLM_OCR_MAX_IMAGE_MB=


# ------------------------------------------------------------
# 2.5 视觉预分类+摘要 (Qwen3-Omni Captioner)
# ------------------------------------------------------------
# 用于工作流首个节点：对证据图片做视觉预分类(chat_screenshot/product_order/...)并生成文本摘要
# 未配置 API Key 时自动回退到 LLM_API_KEY（文本 LLM 凭证）
LLM_CAPTIONER_PROVIDER=siliconflow
LLM_CAPTIONER_API_KEY=
LLM_CAPTIONER_BASE_URL=https://api.siliconflow.cn/v1
LLM_CAPTIONER_MODEL=Qwen/Qwen3-Omni-30B-A3B-Captioner
LLM_CAPTIONER_TEMPERATURE=0.1
LLM_CAPTIONER_TIMEOUT=30
LLM_CAPTIONER_MAX_RETRIES=2


# ------------------------------------------------------------
# 3. PaddleOCR-VL 云端（aistudio 在线服务）
# ------------------------------------------------------------
# 适用场景：高精度文档识别（支持版面分析、表格、公式等）
# 适用策略：OCR_STRATEGIES 中包含 "paddleocr_vl" 时生效
# 与 LLM_OCR_* 完全独立，使用 aistudio 平台的鉴权方式（bearer Token）
# 申请地址：https://aistudio.baidu.com/paddleocr/

# 鉴权 Token（必填，未配置则策略自动跳过）
PADDLEOCR_VL_TOKEN=

# 任务提交地址（默认官方地址，一般无需修改）
PADDLEOCR_VL_BASE_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

# 模型名（默认 PaddleOCR-VL-1.6）
PADDLEOCR_VL_MODEL=PaddleOCR-VL-1.6

# 版面/文档预处理开关（true/false，按需启用）
PADDLEOCR_VL_USE_DOC_ORIENTATION=false
PADDLEOCR_VL_USE_DOC_UNWARPING=false
PADDLEOCR_VL_USE_CHART_RECOGNITION=false

# 轮询参数
PADDLEOCR_VL_POLL_INTERVAL=3
PADDLEOCR_VL_POLL_TIMEOUT=180

# 单次 HTTP 请求超时秒（提交任务 / 查询状态 / 下载结果共用）
PADDLEOCR_VL_REQUEST_TIMEOUT=60


# ------------------------------------------------------------
# 4. LangExtract（基于 Qwen3 的信息抽取，字段抽取首选）
# ------------------------------------------------------------
# LangExtract 是 Google 开源的信息抽取库，支持 OpenAI 兼容接口
# 官方文档：https://github.com/google/langextract
# 本项目通过 OpenAI 兼容接口调用 Qwen3 系列模型（仅用于 LangExtract）
# 未配置则自动回退到 with_structured_output + Pydantic（文本 LLM 降级方案）

# Qwen3 API Key（必填，未配置则降级到 with_structured_output）
# 推荐使用 SiliconFlow：https://cloud.siliconflow.cn/account/ak
# 也可使用阿里云 DashScope：https://dashscope.console.aliyun.com/apiKey
LANGEXTRACT_API_KEY=

# 接口地址（OpenAI 兼容协议）
# SiliconFlow：https://api.siliconflow.cn/v1
# DashScope ：https://dashscope.aliyuncs.com/compatible-mode/v1
LANGEXTRACT_BASE_URL=https://api.siliconflow.cn/v1

# 提供商类型（langextract 内部路由用，OpenAI 兼容接口固定为 openai）
LANGEXTRACT_PROVIDER=openai

# 模型名（Qwen3 系列，仅作为 langextract 使用）
# 推荐：
#   Qwen/Qwen3-8B       速度快，适合实时场景
#   Qwen/Qwen3-32B      精度更高，推荐用于字段抽取（默认）
#   Qwen/Qwen3-235B-A22B 最强，复杂场景兜底
LANGEXTRACT_MODEL=Qwen/Qwen3-32B

# 提取轮数（提高召回率，默认 1，长文档建议 3）
LANGEXTRACT_PASSES=1

# 提取任务的 prompt 描述（留空使用内置默认）
# 内置默认描述维权场景的字段类别（详见 backend/api/agents/examples.py）
LANGEXTRACT_PROMPT=


# ------------------------------------------------------------
# 5. LLM 通用调用参数（跨场景共享的重试/超时策略）
# ------------------------------------------------------------
# 这些参数应用于所有 LLM 场景（文本 LLM / OCR 视觉 LLM / LangExtract）
# 仅在对应场景未显式配置时作为 fallback

# 应用层重试次数（tenacity 指数退避，留空使用各场景的 MAX_RETRIES）
LLM_COMMON_RETRY_MAX_ATTEMPTS=3

# 指数退避起始等待秒（留空使用默认 2）
LLM_COMMON_RETRY_WAIT_MIN=2

# 指数退避最大等待秒（留空使用默认 10）
LLM_COMMON_RETRY_WAIT_MAX=10

# OCR 策略级重试参数（仅 OCR Pipeline 使用）
# 重试次数（网络异常/超时时触发）
OCR_RETRY_MAX_ATTEMPTS=3
# 指数退避最小等待秒
OCR_RETRY_WAIT_MIN=1
# 指数退避最大等待秒
OCR_RETRY_WAIT_MAX=8


# ============================================================
# OCR 引擎配置（多策略链）
# ============================================================

# Tesseract 可执行文件路径（留空则按 PATH 查找，再回退 Windows 默认路径）
# Windows: D:\tesseract\tesseract.exe
# Linux:   /usr/bin/tesseract
TESSERACT_CMD=

# 中文字体文件路径（PDF 导出用，留空则自动查找）
# Windows: C:\Windows\Fonts\simsun.ttc
# Linux:   /usr/share/fonts/truetype/wqy/wqy-microhei.ttc
SIMSUN_PATH=


# ============================================================
# 6. LangGraph Checkpointer 持久化（PostgreSQL，独立于业务 MySQL）
# ============================================================
# LangGraph 官方未提供 MySQLSaver，故引入独立 PostgreSQL 实例专存
# HITL 中断状态/checkpointer 状态（与业务 MySQL 物理隔离）。
# 业务数据仍在 MySQL，PG 仅存 checkpointer 状态。
# 启动 PostgreSQL：docker run -d --name claimcraft-pg -e POSTGRES_DB=claimcraft_checkpoints \
#   -e POSTGRES_USER=claimcraft -e POSTGRES_PASSWORD=claimcraft_dev_2025 -p 5432:5432 postgres:16-alpine

# PostgreSQL 连接串（本地开发直连 127.0.0.1；Docker 部署时改为 postgres-checkpointer）
CHECKPOINTER_DB_URL=postgresql://claimcraft:claimcraft_dev_2025@127.0.0.1:5432/claimcraft_checkpoints

# PostgreSQL 密码（仅 docker-compose 用，本地直连不需要单独配置）
CHECKPOINTER_PG_PASSWORD=claimcraft_dev_2025

# 连接池大小（默认 20，gunicorn 3 workers × 20 = 60 最大连接）
# 生产环境建议根据 PG max_connections 调整（PG 默认 max_connections=100）
CHECKPOINTER_POOL_SIZE=20

# v3 新增：连接池调优参数（留空使用默认值）
# 预热连接数（启动时即建立，避免冷启动延迟，默认 5）
CHECKPOINTER_POOL_MIN_SIZE=5
# 获取连接等待超时秒（默认 5，过短可能误判，生产可调到 10）
CHECKPOINTER_POOL_TIMEOUT=5
# 空闲连接最大保留秒数（超过则关闭，默认 300）
CHECKPOINTER_POOL_MAX_IDLE=300


# ============================================================
# 7. LangSmith 观察配置（LangChain 全链路追踪、调试、评估）
# ============================================================
# 官方文档：https://docs.langchain.com/langsmith/trace-with-langchain
# 申请 API Key：https://smith.langchain.com/settings
# 启用后所有 LLM 调用、节点执行、interrupt/resume 都会自动上报 trace
# 不填则禁用 tracing（生产环境建议启用，开发环境按需）

# 是否启用 LangSmith tracing（true/false，默认 false）
LANGSMITH_TRACING=false

# LangSmith API Key（启用 tracing 时必填，前缀通常为 lsv2_）
LANGSMITH_API_KEY=

# LangSmith 端点（默认 https://api.smith.langchain.com，自托管可改）
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 项目名（用于在 LangSmith 中分组查看 trace）
LANGSMITH_PROJECT=claimcraft-creative

# 采样率（0-1，1=全量，0.1=10% 采样，默认 1）
LANGSMITH_SAMPLING_RATE=1

# 区域端点（us/eu/ap/cn，留空则使用 LANGSMITH_ENDPOINT）
# 用于在多区域 LangSmith Cloud 间路由；本地自托管留空
LANGSMITH_REGION=

# Workspace ID（多 workspace 隔离时填写，留空则使用默认 workspace）
LANGSMITH_WORKSPACE_ID=

# OCR 策略链（逗号分隔，按优先级）
# 可选：tesseract, paddleocr, paddleocr_vl, llm_vision, mock
# 当前四级链路：PaddleOCR-VL 云端 → LLM 视觉 → PaddleOCR 本地 → Mock 兜底
OCR_STRATEGIES=paddleocr_vl,llm_vision,paddleocr,mock

# PaddleOCR 本地策略开关
OCR_PADDLEOCR_ENABLED=true


# ============================================================
# 8. Embedding 服务配置（v10 新增 - RAG 知识库向量检索）
# ============================================================
# 模型：BAAI/bge-large-zh-v1.5（中文优化，1024 维，硅基流动 SiliconFlow 托管）
# 申请 API Key：https://cloud.siliconflow.cn
# 切换模型时请同步修改 EMBEDDING_VECTOR_DIM（rag_service.py 读取）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSIONS=1024

# 法条向量维度（必须与 EMBEDDING_MODEL 原生维度一致，用于 PG 表结构）
# BAAI/bge-large-zh-v1.5：1024
# Qwen/Qwen3-VL-Embedding-8B：4096（不支持降维）
EMBEDDING_VECTOR_DIM=1024


# ============================================================
# 8.1 法条关键词 LLM 提取配置（v10 新增 - 关键词数据质量修复）
# ============================================================
# 用于为每条法条基于 content 生成独立的 keywords（替代整部法律共用 keywords）
# 使用 OpenAI 兼容接口（推荐 SiliconFlow 托管的 Qwen3 系列模型）
# 未配置 API Key 时跳过关键词提取，保留原 keywords 数据
LLM_KEYWORD_API_KEY=
LLM_KEYWORD_BASE_URL=https://api.siliconflow.cn/v1
LLM_KEYWORD_MODEL=Qwen/Qwen3-8B
LLM_KEYWORD_TEMPERATURE=0.1
LLM_KEYWORD_TIMEOUT=60
LLM_KEYWORD_MAX_RETRIES=3
LLM_KEYWORD_BATCH_SIZE=10
# 最大并发数（默认 8，SiliconFlow 免费模型支持较高并发）
LLM_KEYWORD_MAX_CONCURRENT=8


# ============================================================
# 9. RAG 检索配置（v10 新增 - evidence_chain_node 注入法条）
# ============================================================
RAG_ENABLED=true
RAG_TOP_K=10
RAG_SCORE_THRESHOLD=0.3


# ============================================================
# 9.1 Rerank 重排配置（v10 新增 - 三阶段 RAG：粗排→RRF→Rerank）
# ============================================================
# 使用 Cross-encoder 对粗排候选做精排，适合法律/医疗等高严谨领域
# 模型：BAAI/bge-reranker-v2-m3（SiliconFlow /v1/rerank 端点，非 OpenAI 兼容）
# 未配置 API Key 时自动降级为 RRF 顺序截断（不影响检索功能）
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# 最终返回 top-n 条（送入 LLM 的法条数，建议与 RAG_TOP_K 一致）
RERANK_TOP_N=10

# 粗排候选上限（送入 rerank 的数量，50 条平衡精度与速度）
RERANK_CANDIDATE_LIMIT=50

# rerank 分数阈值（0=不过滤，低于此分的丢弃）
RERANK_SCORE_THRESHOLD=0.0

# HTTP 超时秒
RERANK_TIMEOUT=30

# 失败重试次数
RERANK_MAX_RETRIES=2


# ============================================================
# 10. Tools 工具集配置（v10 新增 - complaint_node 主动调用）
# ============================================================
TOOLS_ENABLED=true
TOOLS_MAX_ITERATIONS=5


# ============================================================
# 11. 法律知识库数据源配置（v10 新增）
# ============================================================
# 法条向量索引存 PostgreSQL（pgvector），复用 checkpointer 实例
LAW_VECTOR_DB_URL=postgresql://claimcraft:claimcraft_dev_2025@127.0.0.1:5432/claimcraft_checkpoints
